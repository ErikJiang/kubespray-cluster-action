# --- 修改：容器启动命令，使其作为 SSH 可访问节点运行 ---
# 如果上面配置了非 root 用户，CMD 应在该用户上下文中执行或调整
EXPOSE 22
CMD ["/usr/sbin/sshd", "-D"]